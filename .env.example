APP_NAME="Jogo da Rafaela"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Banco de dados ─────────────────────────────────────────────
# Produção: MariaDB (driver mysql).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=jogo_rafaela
DB_USERNAME=rafaela_user
DB_PASSWORD=

# Dev local rápido com SQLite — comente o bloco acima e use:
# DB_CONNECTION=sqlite
# (depois rode: touch database/database.sqlite)

# ─── Sessão ─────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Em produção (HTTPS) defina SESSION_SECURE_COOKIE=true
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

CACHE_STORE=file

QUEUE_CONNECTION=sync

MAIL_MAILER=log

# ─── Admin do painel ────────────────────────────────────────────
# A senha é guardada como HASH, nunca em texto puro.
# Gere com: php artisan tinker --execute="echo Hash::make('SUA_SENHA');"
ADMIN_EMAIL=samirhv@me.com
ADMIN_PASSWORD_HASH=

VITE_APP_NAME="${APP_NAME}"
